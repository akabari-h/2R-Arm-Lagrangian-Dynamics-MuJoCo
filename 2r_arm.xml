<mujoco model="2R_planar_arm">
  <compiler angle="radian" autolimits="true"/>
  <option gravity="0 0 -9.81" timestep="0.001"/>

  <!-- ASSETS: define materials for visual appearance -->
  <asset>
    <material name="link1_mat" rgba="0.9 0.4 0.1 1" shininess="0.8" specular="0.5"/>
    <material name="link2_mat" rgba="0.25 0.25 0.25 1" shininess="0.8" specular="0.5"/>
    <material name="floor_mat" rgba="0.5 0.5 0.5 1" shininess="0.1"/>
  </asset>

  <!-- VISUAL: global rendering settings -->
  <visual>
    <headlight ambient="0.3 0.3 0.3" diffuse="0.6 0.6 0.6" specular="0.1 0.1 0.1"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <worldbody>

    <!-- ========== LIGHTING ========== -->
    <!-- Main overhead light -->
    <light name="main_light"
           pos="0 -2 4"
           dir="0 0.4 -1"
           diffuse="0.8 0.8 0.8"
           specular="0.3 0.3 0.3"
           castshadow="true"/>

    <!-- Fill light from the side -->
    <light name="fill_light"
           pos="3 -1 2"
           dir="-1 0.2 -0.5"
           diffuse="0.4 0.4 0.4"
           specular="0.1 0.1 0.1"
           castshadow="false"/>

    <!-- ========== FLOOR ========== -->
    <!-- Floor plane at z = -2.5 (well below arm reach of 2m) -->
    <geom name="floor"
          type="plane"
          pos="0 0 -2.5"
          size="5 5 0.1"
          material="floor_mat"
          contype="0"
          conaffinity="0"/>
    <!--
      contype="0" conaffinity="0" means NO collision with anything
      Change pos z value to move floor up/down
      Change size to make floor bigger/smaller
    -->

    <!-- ========== ROBOT ARM ========== -->
    <body name="base" pos="0 0 0">
      <joint name="joint1" type="hinge" axis="0 1 0" pos="0 0 0"
             damping="0" frictionloss="0"/>

      <!-- Thicker link 1 -->
      <geom name="link1" type="capsule" size="0.04 0.5" mass="1.0"
            pos="0.5 0 0" quat="0.707 0 0.707 0" material="link1_mat"/>

      <!-- Joint sphere at base -->
      <geom name="joint1_sphere" type="sphere" size="0.06" pos="0 0 0"
            mass="0" rgba="0.2 0.2 0.2 1"/>

      <body name="link2_body" pos="1 0 0">
        <joint name="joint2" type="hinge" axis="0 1 0" pos="0 0 0"
               damping="0" frictionloss="0"/>

        <!-- Joint sphere at elbow -->
        <geom name="joint2_sphere" type="sphere" size="0.06" pos="0 0 0"
              mass="0" rgba="0.2 0.2 0.2 1"/>

        <!-- Thicker link 2 -->
        <geom name="link2" type="cylinder" size="0.04 0.5" mass="1.0"
              pos="0.5 0 0" quat="0.707 0 0.707 0" material="link2_mat"/>

        <!-- End-effector sphere -->
        <geom name="tip_sphere" type="sphere" size="0.05" pos="1 0 0"
              mass="0" rgba="1 1 0 1"/>

        <site name="tip" pos="1 0 0" size="0.03"/>
      </body>
    </body>

  </worldbody>
</mujoco>